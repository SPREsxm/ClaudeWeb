# ===========================================
# Claude Web — AI Backend 配置
# ===========================================

# AI 模式优先级（自动检测）：
#   1. Claude CLI 模式（如果系统安装了 Claude Code）
#   2. API Key 模式（如果配置了 ANTHROPIC_API_KEY）
#   3. 离线模式（提示用户配置）

# -------------------------------------------
# 方式一：Claude CLI 模式（推荐，无需额外配置）
# -------------------------------------------
# 如果系统已安装 Claude Code CLI，会自动检测并使用。
# 网页中的消息会转发给本地 Claude Code 处理，
# 就像在终端中直接使用 Claude Code 一样。

# -------------------------------------------
# 方式二：API Key 模式（当 CLI 不可用时的后备方案）
# -------------------------------------------
# 在 https://console.anthropic.com 申请
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Claude 模型（可选）
# 可选: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001
# CLAUDE_MODEL=claude-sonnet-4-6

# -------------------------------------------
# 服务器配置
# -------------------------------------------
# 后端端口（默认 4000）
# PORT=4000

# 默认工作区路径（可在网页设置面板中修改）
# WORKSPACE_ROOT=

# 运行环境
# NODE_ENV=development
